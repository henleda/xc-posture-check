# XC Posture Check — env var template
#
# Copy this file to .env.local for local development and fill in real values.
# Production values live in Vercel (Project → Settings → Environment Variables).
# Preview environment is mirrored from Dan via `vercel env add ... preview`.
#
# Source of truth for the required-keys list: CLAUDE.md > Secrets handling.
# Never commit real values. .env* is gitignored except this file.

# ---------- Database ----------
# Neon Postgres. Use the pooled connection string for the app and an unpooled
# string for migrations if Drizzle Kit needs one (we add NEON_DATABASE_URL_UNPOOLED
# only if/when migrations require it).
NEON_DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require"

# ---------- Cache and rate limit ----------
UPSTASH_REDIS_URL="https://YOUR-INSTANCE.upstash.io"
UPSTASH_REDIS_TOKEN="UPSTASH_REST_TOKEN"

# ---------- Email ----------
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"

# ---------- Auth (NextAuth / Auth.js) ----------
# Generate NEXTAUTH_SECRET locally with: openssl rand -base64 32
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
# Production: https://f5evolution.com
# Local dev:  http://localhost:3000
NEXTAUTH_URL="http://localhost:3000"
# Dev/preview only. Comma-separated emails permitted to sign in without an @f5.com address.
# Ignored when NODE_ENV=production. See DECISIONS.md ADR-005.
DEV_AUTH_ALLOWLIST=""

# ---------- Background jobs ----------
INNGEST_EVENT_KEY="ingest_event_key"
INNGEST_SIGNING_KEY="signkey-XXXXXXXX"

# ---------- Observability ----------
SENTRY_DSN="https://PUBLIC_KEY@oXXXXXX.ingest.sentry.io/PROJECT_ID"
POSTHOG_API_KEY="phc_xxxxxxxxxxxxxxxxxxxx"
# Optional override; defaults to PostHog Cloud US.
POSTHOG_HOST="https://us.i.posthog.com"

# ---------- Storage ----------
AWS_ACCESS_KEY_ID="AKIA..."
AWS_SECRET_ACCESS_KEY="..."
AWS_S3_BUCKET="xc-posture-check-artifacts"
AWS_REGION="us-east-1"

# ---------- F5 XC API (read-only reference data) ----------
# See CLAUDE.md > XC API integration rules.
XC_API_TOKEN="xc-token"
XC_TENANT_NAME="your-tenant-name"

# ---------- ASN / geolocation enrichment ----------
IPINFO_TOKEN="ipinfo_token"
